import L from "leaflet";
import type { Ctx } from "../state";
import { el, toast } from "../ui/components";
import { DEFAULT_SETTINGS, type GameSettings } from "../types";
import { watchPosition } from "../util/emitter";

function gen8(): string {
  let s = "";
  for (let i = 0; i < 8; i++) s += Math.floor(Math.random() * 10);
  return s;
}

function sliderRow(
  label: string,
  min: number,
  max: number,
  step: number,
  value: number,
  unit: string,
  onChange: (v: number) => void
) {
  const range = el("input", { type: "range", min, max, step, value }) as HTMLInputElement;
  const num = el("input", { type: "number", min, max, step, value, class: "num-mini mono" }) as HTMLInputElement;
  const setFill = () => range.style.setProperty("--fill", `${((+range.value - min) / (max - min)) * 100}%`);
  setFill();
  range.addEventListener("input", () => {
    num.value = range.value;
    setFill();
    onChange(+range.value);
  });
  num.addEventListener("change", () => {
    let v = Math.max(min, Math.min(max, +num.value || min));
    num.value = String(v);
    range.value = String(v);
    setFill();
    onChange(v);
  });
  return el("div", {}, [
    el("label", { class: "field-label" }, [`${label}${unit ? ` (${unit})` : ""}`]),
    el("div", { class: "slider-row" }, [range, num]),
  ]);
}

function toggleRow(label: string, value: boolean, onChange: (v: boolean) => void) {
  const t = el("div", { class: `toggle ${value ? "on" : ""}` });
  t.addEventListener("click", () => {
    const on = !t.classList.contains("on");
    t.classList.toggle("on", on);
    onChange(on);
  });
  return el("div", { class: "row spread" }, [el("span", { class: "muted" }, [label]), t]);
}

export function hostScreen(ctx: Ctx) {
  const s: GameSettings = { ...DEFAULT_SETTINGS };
  const code = gen8();

  const roomInput = el("input", { type: "text", placeholder: "Saturday Manhunt", maxlength: "24" }) as HTMLInputElement;

  // ── live map preview ──
  const mapNode = el("div", { id: "map", style: "position:relative;height:240px;border-radius:18px;overflow:hidden" });
  let map: L.Map | null = null;
  let circle: L.Circle | null = null;
  let marker: L.Marker | null = null;
  let center: { lat: number; lng: number } | null = null;

  const stopGeo = watchPosition(
    (lat, lng) => {
      center = { lat, lng };
      if (!map) initMap();
      else {
        marker?.setLatLng([lat, lng]);
        circle?.setLatLng([lat, lng]);
      }
    },
    () => toast("Location needed for the zone preview", "bad")
  );

  function initMap() {
    if (!center) return;
    map = L.map(mapNode, { zoomControl: false, attributionControl: false, dragging: false, scrollWheelZoom: false, doubleClickZoom: false }).setView(
      [center.lat, center.lng],
      16
    );
    L.tileLayer("https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png", { subdomains: "abcd", maxZoom: 20 }).addTo(map);
    marker = L.marker([center.lat, center.lng]).addTo(map);
    circle = L.circle([center.lat, center.lng], {
      radius: s.maxRadius,
      color: "#36e0c8",
      weight: 2,
      fillColor: "#36e0c8",
      fillOpacity: 0.08,
    }).addTo(map);
    fit();
    setTimeout(() => map?.invalidateSize(), 60);
  }
  function fit() {
    if (!map || !center) return;
    map.fitBounds(L.latLng(center.lat, center.lng).toBounds(s.maxRadius * 2.4), { padding: [20, 20] });
  }

  const radiusRow = sliderRow("Max radius", 50, 1500, 10, s.maxRadius, "m", (v) => {
    s.maxRadius = v;
    s.minRadius = Math.min(s.minRadius, Math.max(20, v - 20));
    circle?.setRadius(v);
    fit();
  });

  const advanced = el("div", { class: "stack" }, [
    toggleRow("Shrink the zone over time", s.shrinking, (v) => (s.shrinking = v)),
    sliderRow("Shrink speed", 1, 40, 1, s.shrinkSpeed, "m/min", (v) => (s.shrinkSpeed = v)),
    sliderRow("Total game time", 5, 120, 5, s.totalTime, "min", (v) => (s.totalTime = v)),
    sliderRow("Number of hunters", 1, 8, 1, s.numHunters, "", (v) => (s.numHunters = v)),
    toggleRow("Auto-assign roles at start", s.autoAssign, (v) => (s.autoAssign = v)),
    sliderRow("Hunter ping interval", 30, 600, 10, s.pingInterval, "s", (v) => (s.pingInterval = v)),
    sliderRow("Hunter ping range", 10, 300, 5, s.pingRange, "m", (v) => (s.pingRange = v)),
    sliderRow("Out-of-zone timer", 15, 180, 5, s.outOfZoneTimer, "s", (v) => (s.outOfZoneTimer = v)),
    toggleRow("Reveal all positions on map", s.revealPositions, (v) => (s.revealPositions = v)),
    el("div", {}, [
      el("label", { class: "field-label" }, ["When a hider is caught / leaves zone"]),
      (() => {
        const seg = el("div", { class: "seg" }, [
          el("button", { class: "active" }, ["Convert to hunter"]),
          el("button", {}, ["Eliminate"]),
        ]);
        const [a, b] = seg.children as unknown as HTMLButtonElement[];
        a.addEventListener("click", () => {
          s.eliminateMode = "convert";
          a.classList.add("active");
          b.classList.remove("active");
        });
        b.addEventListener("click", () => {
          s.eliminateMode = "eliminate";
          b.classList.add("active");
          a.classList.remove("active");
        });
        return seg;
      })(),
    ]),
  ]);

  const advWrap = el("div", { class: "glass card", style: "max-height:0;overflow:hidden;transition:max-height .4s ease;padding:0" });
  const advInner = el("div", { style: "padding:18px" }, [advanced]);
  advWrap.append(advInner);
  let advOpen = false;
  const advToggle = el("button", { class: "btn ghost" }, ["Advanced settings ▾"]);
  advToggle.addEventListener("click", () => {
    advOpen = !advOpen;
    advWrap.style.maxHeight = advOpen ? `${advInner.scrollHeight + 20}px` : "0";
    advToggle.textContent = advOpen ? "Advanced settings ▴" : "Advanced settings ▾";
  });

  const create = el("button", { class: "btn btn-primary" }, ["Create room"]);
  create.addEventListener("click", () => {
    if (!center) {
      toast("Waiting for your GPS location…", "bad");
      return;
    }
    stopGeo();
    map?.remove();
    const engine = ctx.app.startHost(code, s);
    (roomInput.value.trim() && ((engine as any).roomName = roomInput.value.trim()));
    ctx.go("lobby", { code });
  });

  const back = el("button", { class: "btn ghost small", style: "width:auto" }, ["← Back"]);
  back.addEventListener("click", () => {
    stopGeo();
    map?.remove();
    ctx.go("home");
  });

  return {
    cleanup: () => {
      stopGeo();
      map?.remove();
    },
    el: el("div", {}, [
      el("div", { class: "field" }),
      el("div", { class: "row spread" }, [back, el("span", { class: "eyebrow" }, [`room ${code}`])]),
      el("h1", { class: "title", style: "font-size:2.2rem;margin-top:14px" }, ["Set the zone"]),
      el("div", { class: "stack", style: "margin-top:18px" }, [
        el("div", {}, [el("label", { class: "field-label" }, ["Room name"]), roomInput]),
        el("div", { class: "glass card" }, [
          el("div", { class: "kicker", style: "margin-bottom:10px" }, ["Live zone preview"]),
          mapNode,
          el("div", { style: "margin-top:14px" }, [radiusRow]),
        ]),
        advToggle,
        advWrap,
        create,
      ]),
      el("div", { style: "height:20px" }),
    ]),
  };
}
